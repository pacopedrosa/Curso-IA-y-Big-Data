# ──────────────────────────────────────────────────────────────────────────────
#  SmartManuTech — Variables de entorno
#  Copia este archivo como .env y ajusta los valores a tu entorno.
# ──────────────────────────────────────────────────────────────────────────────

# IP externa de la VM accesible desde tu máquina (vía SSH)
KAFKA_EXTERNAL_HOST=192.168.219.29

# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_EXTERNAL_PORT=9092

# ── Cassandra ─────────────────────────────────────────────────────────────────
CASSANDRA_CLUSTER_NAME=SmartManuTechCluster

# ── InfluxDB ──────────────────────────────────────────────────────────────────
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=smartmanutech123
INFLUXDB_ORG=SmartManuTech
INFLUXDB_BUCKET=sensores_iot
INFLUXDB_TOKEN=smartmanutech-influx-token-2024

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123
GRAFANA_EXTERNAL_PORT=3005

# ── API ───────────────────────────────────────────────────────────────────────
API_EXTERNAL_PORT=8000

# ── MinIO (almacenamiento distribuido S3-compatible) ──────────────────────────
MINIO_ACCESS_KEY=smartmanutech
MINIO_SECRET_KEY=smartmanutech123
